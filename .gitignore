# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local LAN sync server's own persisted state (users/sessions/synced keys) —
# regenerated on first boot from src/data/*.json, never committed.
server/data/*
!server/data/.gitkeep

# Uploaded images (originals + compressed variants) — live only on this
# server's own disk, never committed.
server/uploads/*
!server/uploads/.gitkeep

# Disposable, re-fetchable disk cache of news article images (server/newsImageCache.ts) — never committed, not backed up either (see that file's own doc comment).
server/news-image-cache/*
!server/news-image-cache/.gitkeep

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Agent instructions
CLAUDE.md

