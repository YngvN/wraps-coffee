      "home": {
        "title": "Hjem",
        "welcome": "Velkommen til Vite-malen.",
        "hero": {
          "title": "Wraps & Coffee",
          "slogan": "Vi tilbyr friske salater, smakfulle wraps, baguetter og et variert utvalg drikke.",
          "description": "Kvalitetsråvarer, tilberedt ferskt hver dag, i et koselig lokale hvor du kan slappe av, møte venner eller ta med deg noe godt på farten.",
          "cta": "Se menyen",
          "ctaPickup": "Bestill og hent selv",
          "upcomingEvent": "Kommende arrangement"
        },
        "menu": {
          "title": "God mat som metter",
          "summary": "Hos oss finner du ferske og mettende salater med sprø salat og ditt valg av topping, som reke-, tunfisk- eller klassisk cæsarsalat. Wraps er et annet alternativ for de som vil ha noe å spise på farten; fylt med ris og grønnsaker, med varianter som kylling og fetaost, tandoorikylling og vegetariske valg. I tillegg har vi smakfulle baguetter, som kyllingbaguetten med hvitløk, tomat og agurk eller mozzarellabaguetten – perfekte for et mettende måltid.\n\nHvis du har lyst på noe enda mer matfylt, men fortsatt vil ta hensyn til kostholdet ditt, kan nachos servert med ris, ost, grønnsaker og et utvalg kjøttvarianter deles mellom venner – de gir store porsjoner uten å bli for tungt.\n\nAlle disse rettene gir balansert ernæring samtidig som de er deilige, slik at du kan gå mett, men sunn ut av kafeen. Menyen sørger for at det er noe for alle preferanser og kostholdsbehov, med en god balanse mellom smak og helsebevissthet.",
          "cta": "Bestill",
          "ratings": {
            "score": "Vurdert {{rating}} av 5 på {{platform}}"
          }
        },
        "events": {
          "title": "Ikke bare mat",
          "summary": "Wraps & Coffee er mer enn et sted å spise — book lokalet til ditt eget arrangement, eller bli med på quizkvelden vår hver uke.",
          "cta": "Se arrangementene våre",
          "heading": "Hva skjer"
        },
        "location": {
          "title": "Finn oss",
          "intro": "Stikk innom kafeen vår i Oslo — se kartet under for veibeskrivelse."
        },
